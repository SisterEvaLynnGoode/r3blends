{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/hero.mp4",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Accept-Ranges",  "value": "bytes" }
      ]
    },
    {
      "source": "/gallery/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
